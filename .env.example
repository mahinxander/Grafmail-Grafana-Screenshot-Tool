# =============================================================================
# Grafana Screenshot Tool - Environment Configuration
# =============================================================================
# Copy this file to '.env' and fill in your specific values.
# All sensitive credentials should be stored here and never committed to git.
# =============================================================================

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================

# Base URL of your Grafana instance (required)
GRAFANA_URL=http://0.101.0.25:3000

# Dashboard UID - Found in the dashboard URL after /d/
# Example: https://grafana.example.com/d/abc123xyz/my-dashboard
GRAFANA_DASHBOARD_UID=edzu0yqxghmgwf

# Dashboard slug (optional, the human-readable part of the URL)
GRAFANA_DASHBOARD_SLUG=abc

# =============================================================================
# PANEL CONFIGURATION (Multiple Panels Supported)
# =============================================================================

# Panel IDs for individual panel screenshots (comma-separated)
# Supports multiple formats:
#   - Simple: "16,135,42" (uses PANEL_PARAM_TYPE for all)
#   - Explicit: "viewPanel:16,viewPanel:135,panelId:42" (specify param type per panel)
GRAFANA_PANEL_IDS=10,14

# Legacy: Single panel ID (deprecated, use GRAFANA_PANEL_IDS instead)
# GRAFANA_PANEL_ID=135

# Panel parameter type (default: viewPanel)
# Options: 'viewPanel' (recommended) or 'panelId'
PANEL_PARAM_TYPE=viewPanel

# =============================================================================
# CUSTOM URL PARAMETERS (Grafana Variables)
# =============================================================================

# Additional URL parameters for Grafana dashboard variables
# Use & or , as separator between parameters
# Examples:
#   GRAFANA_CUSTOM_PARAMS=var-collection=store_cell_events&var-nodename=fd54bc8f8e6c&var-node=node-exporter:9100
#   GRAFANA_CUSTOM_PARAMS=var-instance=server1,var-datasource=Prometheus
GRAFANA_CUSTOM_PARAMS=var-collection=store_events

# =============================================================================
# CAPTURE WORKFLOW CONFIGURATION
# =============================================================================

# Capture full dashboard viewport (first step in sequential workflow)
# true = capture the entire dashboard view first
# false = skip viewport capture
CAPTURE_VIEWPORT=true

# Capture individual panels
# true = capture each panel specified in GRAFANA_PANEL_IDS
# false = skip panel captures
CAPTURE_PANELS=true

# Seconds to wait between panel captures
PANEL_LOAD_WAIT=4

# =============================================================================
# SIDEBAR CONFIGURATION
# =============================================================================

# Hide Grafana sidebar in screenshots
# true = hide sidebar
# false = show sidebar in screenshots
HIDE_SIDEBAR=true

# =============================================================================
# TLS/SSL VERIFICATION
# =============================================================================

# Ignore TLS certificate errors when connecting to Grafana
# Set to true for self-signed certificates, false for production
# Applies to both browser (Playwright) and health check (requests)
GRAFANA_IGNORE_TLS_ERRORS=false
# =============================================================================
# AUTHENTICATION
# =============================================================================

# Authentication method: 'token' or 'password' (default: password)
GRAFANA_AUTH_METHOD=token

# Service Account Token (required if GRAFANA_AUTH_METHOD=token)
GRAFANA_SERVICE_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxx

# Username and Password (required if GRAFANA_AUTH_METHOD=password)
GRAFANA_USERNAME=root
GRAFANA_PASSWORD=

# =============================================================================
# SCREENSHOT CONFIGURATION
# =============================================================================

# Viewport dimensions for screenshot (pixels)
# Recommended 1920x1080
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080

# Output format: 'png' or 'pdf'
SCREENSHOT_FORMAT=png

# Capture full page (true) or viewport only (false)
SCREENSHOT_FULL_PAGE=true

# Directory to save screenshots (inside container)
CAPTURE_DIR=/app/captures

# =============================================================================
# DASHBOARD RENDERING OPTIONS
# =============================================================================

# Time range for dashboard data
DASHBOARD_TIME_FROM=now-7d
DASHBOARD_TIME_TO=now

# Dashboard theme: 'dark' or 'light'
DASHBOARD_THEME=dark

# Kiosk mode - hide Grafana UI elements (for viewport capture)
DASHBOARD_KIOSK=true

# Auto-refresh interval (optional)
DASHBOARD_REFRESH=

# =============================================================================
# DELIVERY MODE CONFIGURATION
# =============================================================================

# Delivery mode controls what happens after screenshots are captured:
#   SMTP_INTERNAL = capture + send email via SMTP
#   FILE_ONLY     = capture only, save to CAPTURE_DIR, no email from Docker
DELIVERY_MODE=FILE_ONLY

# =============================================================================
# SMTP CONFIGURATION (when DELIVERY_MODE=SMTP_INTERNAL)
# =============================================================================

# SMTP server configuration
SMTP_HOST=
SMTP_PORT=465

# SMTP credentials (optional — omit for no-auth relay on port 25)
# If your SMTP relay does not require authentication, leave these empty.
SMTP_USER=
SMTP_PASSWORD=

# Email addresses
SMTP_FROM="MY-Grafana-MONITOR <some.tmp@tmp.gov.tmp>"
SMTP_TO=

# CC recipients (comma-separated, optional)
SMTP_CC=

# BCC recipients (comma-separated, optional)
SMTP_BCC=

# Use TLS encryption (set false for internal relay on port 25)
SMTP_USE_TLS=false

# Use SSL encryption (port 465, e.g. Gmail)
# If true, SMTP_USE_TLS is ignored. Uses SMTP_SSL connection.
SMTP_USE_SSL=true

# Email subject line
SMTP_SUBJECT=Grafana Dashboard Report

# Custom email body (optional — overrides the default auto-generated body)
# Leave empty to use the default report body with dashboard metadata.
EMAIL_BODY_MESSAGE="Please receive the reports."

# What to do when no images are captured:
#   notify = send a notification email saying no images were captured
#   skip   = exit gracefully with success (exit code 0)
#   fail   = exit with failure (exit code 2)
NO_IMAGES_ACTION=notify

# =============================================================================
# OPTIONAL REMOTE COPY (FILE_ONLY mode only)
# =============================================================================

# After capturing screenshots, optionally copy them to a remote/secondary path.
# Supports two formats:
#   Local:  /some/mounted/directory
#   SCP:    user@host:/remote/directory
SEND_IMG_TO_REMOTE=true
REMOTE_COPY_PATH=user@host:/path/to/your/destination

# Transfer method for remote copy:
#   paramiko = use Python paramiko library (no system deps needed)
#   local    = use shutil.copy2 (for local/mounted paths only)
REMOTE_COPY_METHOD=paramiko

# SSH host key verification policy (used with paramiko method):
#   warn   = accept unknown keys with a warning (default)
#   reject = reject unknown keys (requires pre-populated known_hosts)
#   auto   = automatically accept all keys (not recommended for production)
# When using 'reject', ensure the remote host is in ~/.ssh/known_hosts
SSH_HOST_KEY_POLICY=warn

# SSH private key path (inside container) for paramiko authentication
# When run via run_report.sh, the host's SSH key is auto-mounted into the container.
# Only set this manually if you need a custom key path.
# Supported key types: RSA, Ed25519, ECDSA, DSS
SSH_KEY_PATH=

# SSH password (alternative to key-based auth)
# Use this if the remote server requires password authentication. (not recommended)
# Leave empty if using SSH key authentication.
SSH_PASSWORD=passwd

# SSH port for paramiko connections (default: 22)
SSH_PORT=22

# =============================================================================
# FILE CLEANUP CONFIGURATION
# =============================================================================

# Delete files older than X days (0 = disabled)
# Applied to both local CAPTURE_DIR and can be run independently
FILE_RETENTION_DAYS=1

# Run cleanup before each capture session
CLEANUP_ON_START=true

# =============================================================================
# ADVANCED OPTIONS
# =============================================================================

# Custom spinner selectors for wait-for-load (comma-separated)
SPINNER_SELECTORS=

# Additional wait time after spinners disappear (seconds)
WAIT_AFTER_LOAD=5

# Debug mode - enables verbose logging
DEBUG_MODE=false

# =============================================================================
# RETRY & TIMEOUT CONFIGURATION
# =============================================================================

# Number of retry attempts for failed screenshot captures
CAPTURE_RETRY_COUNT=2

# Per-dashboard/panel capture timeout in seconds
# Controls how long Playwright waits for page load
CAPTURE_TIMEOUT=60

# =============================================================================
# DOCKER RESOURCE LIMITS (used by run_report.sh)
# =============================================================================

# Memory limit for the Docker container (e.g. 512m, 1g, 2g)
DOCKER_MEMORY=1g

# CPU limit for the Docker container (e.g. 0.5, 1, 1.5, 2)
DOCKER_CPUS=1.5

